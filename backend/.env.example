# ── Server ────────────────────────────────────────────────
PORT=5000

# ── MongoDB ───────────────────────────────────────────────
# Get your connection string from https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/lifetracker?retryWrites=true&w=majority

# ── JWT Secrets ───────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_64_char_hex_secret_here
JWT_REFRESH_SECRET=your_other_64_char_hex_secret_here
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── Gemini AI ─────────────────────────────────────────────
# Get your key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── CORS ──────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173
